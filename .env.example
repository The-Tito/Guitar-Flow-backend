# ── Superusuario de PostgreSQL (solo para inicialización de Docker) ───────────
# No es usado por el backend Node.js. Solo docker-compose lo pasa al contenedor
# para que POSTGRES_USER cree la base de datos y ejecute los scripts de init.
POSTGRES_USER=postgres_admin
POSTGRES_PASSWORD=

# ── Rol de la aplicación (sin superusuario) ───────────────────────────────────
# Creado automáticamente por 00_create_roles.sh en el primer arranque del
# contenedor. El backend se conecta con estas credenciales. RLS se aplica
# porque este rol NO bypassa Row Level Security.
APP_DB_USER=app_guitarist
APP_DB_PASSWORD=

# ── Base de datos compartida ──────────────────────────────────────────────────
DB_NAME=guitarflow
DB_PORT=5432
# DB_HOST solo es necesario en desarrollo local fuera de Docker (default: localhost)
# DB_HOST=localhost

# ── Configuración de la aplicación ───────────────────────────────────────────
# ID del usuario activo cuando no se envía la cabecera x-user-id.
APP_CURRENT_USER_ID=1
APP_PORT=3000

