# PostgreSQL superuser — used by docker-compose for DB initialization
POSTGRES_USER=postgres_admin
POSTGRES_PASSWORD=

# Application DB role — non-superuser, RLS is enforced for this role
APP_DB_USER=app_guitarist
APP_DB_PASSWORD=

# Shared DB config
DB_NAME=guitarflow
DB_PORT=5432

# Local development (connect directly without Docker — use the app role credentials)
DB_HOST=localhost
DB_USER=app_guitarist
DB_PASSWORD=

# Application
APP_CURRENT_USER_ID=1
APP_PORT=3000
